@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Re-find CUDA dependencies that the targets require.
if(NOT TARGET CUDA::cudart)
    find_dependency(CUDAToolkit QUIET)
endif()

if(NOT EXISTS "${CMAKE_CURRENT_LIST_DIR}/cpp_base_suite-targets.cmake")
    set(cpp_base_suite_FOUND FALSE)
    return()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/cpp_base_suite-targets.cmake")

check_required_components(cpp_base_suite)
